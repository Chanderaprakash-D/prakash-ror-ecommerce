<!DOCTYPE html>
<html>
  <head>
    <title>PrakashRorEcommerce</title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
  </head>

  <body>
  <nav style="background:#111827; padding:16px 30px; font-family:Arial;">
  <a href="/" style="color:white; font-size:22px; font-weight:bold; text-decoration:none;">Prakash Store</a>

  <span style="float:right;">
