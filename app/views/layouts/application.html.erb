    <a href="/categories" style="color:white; margin-right:20px; text-decoration:none;">Categories</a>
    <a href="/customers" style="color:white; margin-right:20px; text-decoration:none;">Customers</a>
    <a href="/cart_items" style="color:white; margin-right:20px; text-decoration:none;">Cart</a>
    <a href="/orders" style="color:white; text-decoration:none;">Orders</a>
